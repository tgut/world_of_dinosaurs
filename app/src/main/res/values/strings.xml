    <string name="vision_key_guide_title">How to Get Vision API Key</string>
    <string name="vision_key_guide">1. Go to Google Cloud Console\n\n2. Create a new project (or use an existing one)\n\n3. In the left menu, go to \"APIs &amp; Services\" → \"Library\"\n\n4. Search for \"Cloud Vision API\" and enable it\n\n5. Go to \"APIs &amp; Services\" → \"Credentials\"\n\n6. Click \"Create Credentials\" → \"API Key\"\n\n7. Copy the API key and paste it here</string>
    <string name="vision_key_guide_url">https://console.cloud.google.com/apis/credentials</string>

    <string name="chat_key_guide_title">How to Get Chat API Key</string>
    <string name="chat_key_guide_deepseek">DeepSeek:\n\n1. Go to platform.deepseek.com\n\n2. Register / Sign in\n\n3. Go to \"API Keys\" page\n\n4. Click \"Create new API key\"\n\n5. Copy and paste it here</string>
    <string name="chat_key_guide_deepseek_url">https://platform.deepseek.com/api_keys</string>
    <string name="chat_key_guide_qwen">Qwen (通义千问):\n\n1. Go to dashscope.console.aliyun.com\n\n2. Register / Sign in with Aliyun account\n\n3. Go to \"API-KEY 管理\"\n\n4. Click \"创建新的 API-KEY\"\n\n5. Copy and paste it here</string>
    <string name="chat_key_guide_qwen_url">https://dashscope.console.aliyun.com/apiKey</string>
    <string name="chat_key_guide_gemini">Gemini:\n\n1. Go to aistudio.google.com\n\n2. Sign in with Google account\n\n3. Click \"Get API Key\" in the left menu\n\n4. Click \"Create API Key\"\n\n5. Copy and paste it here</string>
    <string name="chat_key_guide_gemini_url">https://aistudio.google.com/apikey</string>

